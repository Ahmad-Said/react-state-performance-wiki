{
  "name": "poc-react-query-orval-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "fetch:specs": "node ./scripts/fetch-specs.mjs",
