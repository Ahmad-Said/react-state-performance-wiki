    "react-dom": "^19.2.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "orval": "^8.17.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
